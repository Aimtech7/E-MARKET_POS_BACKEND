  },
  "build": {
    "appId": "com.emmarket.pos",
    "productName": "EMMARKET POS",
    "publish": [
      {
        "provider": "github",
        "owner": "Aimtech7",
        "repo": "E-MARKET_POS_BACKEND"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
